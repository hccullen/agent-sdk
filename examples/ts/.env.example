# Copy this file to `.env` and fill in your Corti tenant credentials.
# The examples load it automatically via `dotenv`.

CORTI_TENANT_NAME=your-tenant
CORTI_ENVIRONMENT=eu
CORTI_CLIENT_ID=your-client-id
CORTI_CLIENT_SECRET=your-client-secret

# Optional — only required for examples that attach an MCP server.
MCP_URL=https://mcp.example.com
MCP_TOKEN=
